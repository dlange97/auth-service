APP_ENV=dev
APP_SECRET=change_me_auth_secret
DATABASE_URL="mysql://app:change_me_db_password@mysql:3306/auth?serverVersion=8.4&charset=utf8mb4"

JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_jwt_passphrase
JWT_TOKEN_TTL=3600

CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|[a-z0-9-]+\.mydashboard\.(local|com))(:[0-9]+)?$'
LOCK_DSN=flock
VAR_DUMPER_SERVER=127.0.0.1:9912

NOTIFICATION_SERVICE_URL=http://nginx
INTERNAL_NOTIFICATION_TOKEN=change_me_internal_notification_token
MESSENGER_TRANSPORT_DSN=amqp://guest:guest@rabbitmq:5672/%2f/messages

BASE_URL=http://app.mydashboard.local

# Optional helper values for local test user tooling
ADMIN_EMAIL=admin.test@micro.com
ADMIN_PASSWORD=Admin123!
