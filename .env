
APP_ENV=dev
APP_SECRET=auth_secret_change_me_in_production
DATABASE_URL="mysql://app:secret@mysql:3306/auth?serverVersion=8.4&charset=utf8mb4"
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_in_env_dev
JWT_TOKEN_TTL=2592000
BASE_URL=http://app.mydashboard.local
NOTIFICATION_SERVICE_URL=http://nginx
INTERNAL_NOTIFICATION_TOKEN=change_me_in_env_dev

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
